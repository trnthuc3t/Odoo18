<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_lark_message_hook_tree" model="ir.ui.view">
        <field name="name">lark.message.hook.tree</field>
        <field name="model">lark.message.hook</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="short_name"/>
                <field name="hook_url"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_lark_message_hook_form" model="ir.ui.view">
        <field name="name">lark.message.hook.form</field>
        <field name="model">lark.message.hook</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="short_name"/>
                        </group>
                        <group>
                            <field name="hook_url"/>
                            <field name="hook_url_signature" password="True"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_lark_message_hook" model="ir.actions.act_window">
        <field name="name">Lark Message Hooks</field>
        <field name="res_model">lark.message.hook</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Lark Message Hook
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_lark_message_hook"
              name="Lark Message Hooks"
              parent="base_setup.menu_config"
              action="action_lark_message_hook"
              sequence="99"/>
</odoo>