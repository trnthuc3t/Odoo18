<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_tree_view_inherit" model="ir.ui.view">
        <field name="name">product.product.tree.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_template_variant_value_ids']" position="after">
                <field name="published_on_websites" widget="many2many_tags" string="Published on Websites" options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
