<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_tour_website_tree" model="ir.ui.view">
            <field name="name">tour.website.tree</field>
            <field name="model">tour.website</field>
            <field name="arch" type="xml">
                <list string="Tour Websites" create="true" editable="bottom">
                    <field name="name"/>
                    <field name="short_name"/>
                    <field name="url"/>
                    <field name="pricelist_id" widget="many2one" options="{'no_create': True}"/>
                    <field name="is_active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_tour_website_form" model="ir.ui.view">
            <field name="name">tour.website.form</field>
            <field name="model">tour.website</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="short_name"/>
                            </group>
                            <group>
                                <field name="url"/>
                                <field name="pricelist_id" widget="many2one" options="{'no_create': True}"/>
                                <field name="is_active" widget="boolean_toggle"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_tour_website" model="ir.actions.act_window">
            <field name="name">Tour Websites</field>
            <field name="res_model">tour.website</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Tour Website
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_tour_website"
                  name="Tour Websites"
                  parent="sale.product_menu_catalog"
                  action="action_tour_website"
                  sequence="99"/>
    </data>
</odoo>