<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_create_task_manual_wizard_form" model="ir.ui.view">
        <field name="name">create.task.manual.wizard.form</field>
        <field name="model">create.task.manual.wizard</field>
        <field name="arch" type="xml">
            <form string="Manual Task Creation Wizard">
                <group>
                    <field name="name" required="1"/>
                    <field name="description" required="1"/>
                </group>
                <group string="Assignment">
                    <group>
                        <field name="is_assign_to_me"/>
                        <field name="user_id" required="is_assign_to_me == False"/>
                    </group>
                    <group>
                        <field name="mentor_id"/>
                        <field name="manager_id"/>
                        <field name="department_id" readonly="1"/>
                    </group>
                </group>
                <group string="Dates">
                    <field name="start_date"/>
                    <field name="deadline"/>
                </group>
                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="tag_ids" widget="many2many_tags" required="1"/>
                </group>
                <footer>
                    <button string="Create Task" type="object" name="action_create_task" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_task_manual_wizard" model="ir.actions.act_window">
        <field name="name">Manual Task Creation</field>
        <field name="res_model">create.task.manual.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_create_task_manual_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>