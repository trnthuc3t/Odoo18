<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Task Template Tags -->
        <record id="tag_operation" model="tour.task.template.tag">
            <field name="name">Operation</field>
            <field name="color">2</field>
            <field name="sequence">10</field>
        </record>
        
        <record id="tag_sales" model="tour.task.template.tag">
            <field name="name">Sales</field>
            <field name="color">3</field>
            <field name="sequence">20</field>
        </record>
        
        <record id="tag_guide" model="tour.task.template.tag">
            <field name="name">Tour Guide</field>
            <field name="color">4</field>
            <field name="sequence">30</field>
        </record>
        
        <record id="tag_verification" model="tour.task.template.tag">
            <field name="name">Verification</field>
            <field name="color">1</field>
            <field name="sequence">40</field>
        </record>

