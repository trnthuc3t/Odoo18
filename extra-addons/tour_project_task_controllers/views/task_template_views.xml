<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Task Template Tree View -->
    <record id="view_task_template_tree" model="ir.ui.view">
        <field name="name">tour.task.template.tree</field>
        <field name="model">tour.task.template</field>
        <field name="arch" type="xml">
            <list string="Task Templates" decoration-muted="not is_active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <!-- <field name="product_ids" widget="many2many_tags"/>
                <field name="product_template_ids" widget="many2many_tags"/> -->
                <field name="department_id"/>
                <field name="user_id"/>
                <field name="duration"/>
                <field name="duration_unit"/>
                <field name="priority" widget="priority"/>
                <field name="task_type"/>
                <field name="tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="task_categories" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="is_active" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Task Template Form View -->
    <record id="view_task_template_form" model="ir.ui.view">
        <field name="name">tour.task.template.form</field>
        <field name="model">tour.task.template</field>
        <field name="arch" type="xml">
            <form string="Task Template">
                <sheet>
                    <!-- <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="is_active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div> -->
                    <field name="is_active" widget="boolean_button" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" 
                            invisible="is_active"/>
                    
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Prepare tour itinerary"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group name="basic_info">
                            <field name="sequence"/>
                            <field name="priority" widget="priority"/>
                            <field name="task_type"/>
                            <field name="tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="task_categories" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group name="product_link">
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="product_template_ids" widget="many2many_tags"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Assignment" name="assignment">
                            <group>
                                <group name="assignment_user">
                                    <field name="user_id" invisible="is_assign_salesperson"/>
                                    <field name="is_assign_salesperson"/>
                                    <field name="is_export_invoice_vat_template" invisible="is_assign_salesperson" string="Invoice VAT Template"/>
                                    <field name="is_no_duplicate_task" string="No Duplicate Task" widget="boolean_button"/>
                                    <field name="mentor"/>
                                    <field name="manager_id"/>
                                </group>
                                <group name="assignment_team">
                                    <field name="department_id"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Scheduling" name="scheduling">
                            <group>
                                <group name="duration">
                                    <label for="duration"/>
                                    <div class="o_row">
                                        <field name="duration" class="oe_inline"/>
                                        <field name="duration_unit" class="oe_inline"/>
                                        <span class="text-muted ml8">
                                            (<field name="duration_in_minutes" readonly="1"/> minutes)
                                        </span>
                                    </div>
                                    <label for="start_offset"/>
                                    <div class="o_row">
                                        <field name="start_offset" class="oe_inline"/>
                                        <field name="start_offset_unit" class="oe_inline"/>
                                        <span class="text-muted ml8">after payment</span>
                                    </div>
                                </group>
                            </group>
                            <group string="Dependencies">
                                <field name="depends_on_ids" widget="many2many_tags" 
                                       domain="[('id', '!=', id)]"
                                       placeholder="Select tasks that must be completed before this one"/>
                                <field name="blocking_ids" widget="many2many_tags" readonly="1"/>
                            </group>
                        </page>
                        
                        <page string="Description" name="description">
                            <field name="description" widget="html" 
                                   placeholder="Describe the task in detail..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Task Template Kanban View -->
    <record id="view_task_template_kanban" model="ir.ui.view">
        <field name="name">tour.task.template.kanban</field>
        <field name="model">tour.task.template</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="product_template_ids">
                <field name="name"/>
                <field name="priority"/>
                <field name="tags"/>
                <field name="task_categories"/>
                <field name="duration"/>
                <field name="duration_unit"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="float-end">
                                    <field name="priority" widget="priority"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <field name="task_categories" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <div class="text-muted">
                                    <i class="fa fa-clock-o"/> <field name="duration"/> <field name="duration_unit"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Task Template Search View -->
    <record id="view_task_template_search" model="ir.ui.view">
        <field name="name">tour.task.template.search</field>
        <field name="model">tour.task.template</field>
        <field name="arch" type="xml">
            <search string="Task Templates">
                <field name="name"/>
                <field name="product_ids"/>
                <field name="product_template_ids"/>
                <field name="user_id"/>
                <field name="department_id"/>
                <field name="tags"/>
                <separator/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ['2', '3'])]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Product Template" name="group_product_template_ids"
                            context="{'group_by': 'product_template_ids'}"/>
                    <filter string="Department" name="group_department" 
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Assigned User" name="group_user" 
                            context="{'group_by': 'user_id'}"/>
                    <filter string="Task Type" name="group_type" 
                            context="{'group_by': 'task_type'}"/>
                    <filter string="Priority" name="group_priority" 
                            context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Task Template Action -->
    <record id="action_task_template" model="ir.actions.act_window">
        <field name="name">Task Templates</field>
        <field name="res_model">tour.task.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_active': 1, 'search_default_group_product_template_ids': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Task Template
            </p>
            <p>
                Task templates are automatically created when products/services are sold.
                Configure which tasks should be generated for each product.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_task_template_root"
              name="Task Templates"
              parent="project.menu_project_config"
              sequence="20"/>
              
    <menuitem id="menu_task_template"
              name="Task Templates"
              parent="menu_task_template_root"
              action="action_task_template"
              sequence="10"/>

    <!-- Task Template Tag Views -->
    <record id="view_task_template_tag_tree" model="ir.ui.view">
        <field name="name">tour.task.template.tag.tree</field>
        <field name="model">tour.task.template.tag</field>
        <field name="arch" type="xml">
            <list string="Task Template Tags" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_task_template_tag" model="ir.actions.act_window">
        <field name="name">Task Template Tags</field>
        <field name="res_model">tour.task.template.tag</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_task_template_tag"
              name="Task Tags"
              parent="menu_task_template_root"
              action="action_task_template_tag"
              sequence="20"/>

</odoo>
