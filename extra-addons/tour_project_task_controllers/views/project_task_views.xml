    <!-- Inherit Project Task Kanban View -->
    <record id="view_task_kanban_inherit_task_template" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.task.template</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="mentor_id"/>
                <!-- <field name="can_start"/>
                <field name="has_dependencies"/> -->
            </xpath>
        </field>
    </record>

    <record id="task_type_tree_inherit_usable" model="ir.ui.view">
        <field name="name">project.task.type.tree.inherit.usable</field>
        <field name="model">project.task.type</field>
        <field name="inherit_id" ref="project.task_type_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fold']" position="after">
                <field name="is_usable"/>
            </xpath>
        </field>
    </record>

