<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Invoice Form View -->
    <record id="view_move_form_inherit_task_template" model="ir.ui.view">
        <field name="name">account.move.form.inherit.task.template</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add fields in form -->
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="tasks_generated" readonly="1" invisible="move_type != 'out_invoice'" groups="base.group_system"/>
                <field name="is_guarantee_invoice" invisible="0" groups="base.group_system"/>
            </xpath>
            <xpath expr="//button[@name='button_cancel']" position="after">
                <button name="confirm_and_guarantee_payment" type="object" 
                    string="Confirm and Guarantee Payment" class="btn-danger" 
                    confirm="Bạn có chắc chắn muốn bảo lãnh, Project và Tasks sẽ được khởi tạo cho các dịch vụ ở Invoice này dù Invoice chưa thanh toán"
                    invisible="is_guarantee_invoice or move_type != 'out_invoice' or state != 'draft'"
                />
            </xpath>
        </field>
    </record>

    <!-- Inherit Invoice Tree View -->
    <record id="view_move_tree_inherit_task_template" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.task.template</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='status_in_payment']" position="after">
                <field name="is_guarantee_invoice" optional="hide" widget="boolean"/>
            </xpath>
        </field>
    </record>

</odoo>
