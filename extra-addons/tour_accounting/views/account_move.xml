<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_invoice_sent']" position="before">
                <button name="action_generate_payment_link"
                        type="object"
                        string="Generate Payment Link"
                        class="btn btn-primary o_form_button"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund') or payment_state != 'not_paid'"/>
            </xpath>
            <xpath expr="//label[@for='invoice_date']" position="before">
                <field name="order_id" readonly="1" widget="many2one" optional="show"/>
            </xpath>
            <xpath expr="//form" position="attributes">
                <attribute name="create">false</attribute>
                <attribute name="import">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_out_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="order_id" readonly="1" widget="many2one" optional="show"/>
            </xpath>
            <xpath expr="//list" position="attributes">
                <attribute name="create">false</attribute>
                <attribute name="import">false</attribute>
                <attribute name="export_xlsx">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>

    <record id="account_payment.action_invoice_order_generate_link" model="ir.actions.act_window">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_view_types"></field>
    </record>
</odoo>
