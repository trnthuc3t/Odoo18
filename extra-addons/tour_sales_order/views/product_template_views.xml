<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Detail Information tab to Product Template Form -->
    <record id="view_product_template_form_inherit_detail" model="ir.ui.view">
        <field name="name">product.template.form.inherit.detail</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page string="Detail Information" name="detail_information">
                    <field name="detail_information" widget="html" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Popup View for Detail Information -->
    <record id="view_product_template_detail_popup" model="ir.ui.view">
        <field name="name">product.template.detail.popup</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="Detail Information">
                <sheet>
                    <field name="detail_information" widget="html" readonly="1"/>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
